<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.peteedoo.hermes-job-hunt</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/opt/python@3.11/libexec/bin/python3</string>
        <string>/Users/peteedoo/.hermes/scripts/job-hunt/orchestrator.py</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/peteedoo/.hermes/scripts/job-hunt/logs/orchestrator.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/peteedoo/.hermes/scripts/job-hunt/logs/orchestrator.error.log</string>
</dict>
</plist>
